pipeline {
    agent any

    tools {
        jdk 'jdk21'
        nodejs 'node20'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/iampooji/panigrahan_matrimony_app.git'
            }
        }

        stage('Verify Workspace') {
            steps {
                sh '''
                pwd
                ls -la
                find client -type f | head -50 || true
                find server -type f | head -50 || true
                '''
            }
        }

        stage('Verify NodeJS') {
            steps {
                sh '''
                node -v
                npm -v
                '''
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir('client') {
                    sh 'npm install'
                }
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir('server') {
                    sh 'npm install'
                }
            }
        }

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh """
                    ${SCANNER_HOME}/bin/sonar-scanner \
                    -Dsonar.projectKey=panigrahan_matrimony_app \
                    -Dsonar.projectName=panigrahan_matrimony_app \
                    -Dsonar.sources=client/src,server \
                    -Dsonar.sourceEncoding=UTF-8 \
                    -Dsonar.exclusions=**/node_modules/**,**/dist/**,**/build/**,**/coverage/**
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }
    }

    post {
        success {
            echo 'Panigrahan Web App pipeline completed successfully!'
        }

        failure {
            echo 'Pipeline failed. Check Console Output.'
        }
    }
}